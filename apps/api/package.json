{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema prisma/schema.prisma && tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "zod": "^3.24.1",
    "nodemailer": "^6.10.1",
    "@prisma/client": "^6.3.1",
    "dotenv": "^16.4.7",
    "design-system": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.10.10",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "prisma": "^6.3.1",
    "vitest": "^2.1.8",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0"
  }
}
